---
import "../styles/global.css";
import { content } from "../data/content";
import { companyData } from "../data/company";

const { title = content.meta.title } = Astro.props;
const phonePrimaryClean = companyData.phone.primary.replace(/\s/g, '');
---

<html lang="en" class="scroll-smooth">
    <head>
        <meta charset="utf-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1" />
        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
        <title>{title}</title>
        <meta name="theme-color" content="#0a0a0a" />
        <meta name="color-scheme" content="dark" />
        <meta name="description" content={content.meta.description} />
    </head>
    <body class="bg-[#0a0a0a] text-zinc-100 antialiased selection:bg-zinc-200/20 selection:text-white">
        <header class="sticky top-0 z-40 backdrop-blur supports-[backdrop-filter]:bg-black/40">
            <div class="mx-auto max-w-7xl px-6 py-4 flex items-center justify-between">
                <a href="/" class="inline-flex items-center gap-2 group">
                    <span class="h-3 w-3 rounded-full bg-zinc-200 group-hover:bg-white transition-colors"></span>
                    <span class="font-semibold tracking-wide">{companyData.name}</span>
                </a>
                <nav class="hidden md:flex items-center gap-6 text-sm text-zinc-300">
                    <a href="#work" class="hover:text-white">Work</a>
                    <a href="#services" class="hover:text-white">Services</a>
                    <a href="#contact" class="hover:text-white">Contact</a>
                </nav>
                <a href="#contact" class="ml-6 inline-flex items-center rounded-full border border-zinc-800 bg-white/5 px-4 py-2 text-sm text-zinc-100 hover:bg-white/10">
                    Start a Project
                </a>
            </div>
        </header>

        <main class="mx-auto max-w-7xl px-6">
            <slot />
        </main>

        <footer class="mt-24 border-t border-white/10">
            <div class="mx-auto max-w-7xl px-6 py-8">
                <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-4 mb-6">
                    <div>
                        <p class="text-xs text-zinc-400">© {new Date().getFullYear()} {companyData.name}. All rights reserved.</p>
                    </div>
                    <div class="flex flex-col gap-2 text-sm text-zinc-300">
                        <a href={`tel:${phonePrimaryClean}`} class="hover:text-white">
                            📞 {companyData.phone.primary} | {companyData.phone.secondary}
                        </a>
                        <a href={`mailto:${companyData.email}`} class="hover:text-white">
                            📧 {companyData.email}
                        </a>
                        <a href={companyData.social.instagram.url} target="_blank" rel="noopener noreferrer" class="hover:text-white">
                            📸 Instagram: {companyData.social.instagram.handle}
                        </a>
                    </div>
                </div>
            </div>
        </footer>
    </body>
</html>