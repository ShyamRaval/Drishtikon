---
import Layout from "../layouts/Layout.astro";
import { content } from "../data/content";
import { companyData } from "../data/company";
---

<Layout>
    <!-- Hero Section -->
    <section class="relative py-20 md:py-32 lg:py-40 overflow-hidden">
        <div class="max-w-4xl">
            <h1 class="text-5xl md:text-7xl lg:text-8xl font-bold tracking-tight leading-[1.1] mb-6">
                {content.hero.title}
            </h1>
            <p class="text-xl md:text-2xl text-zinc-300 leading-relaxed mb-4 max-w-3xl">
                {content.hero.description}
            </p>
            <p class="text-lg md:text-xl text-zinc-400 leading-relaxed mb-8 max-w-3xl">
                {content.hero.subtitle}
            </p>
            <div class="flex flex-wrap gap-4">
                <a href="#contact" class="inline-flex items-center rounded-full bg-white text-black px-6 py-3.5 text-base font-semibold hover:bg-zinc-100 transition-all duration-200 shadow-lg shadow-white/20 hover:shadow-xl hover:shadow-white/30 hover:scale-105">
                    {content.hero.cta.primary}
                </a>
                <a href="#work" class="inline-flex items-center rounded-full border-2 border-white/30 bg-white/5 backdrop-blur-sm px-6 py-3.5 text-base font-semibold text-white hover:bg-white/10 hover:border-white/50 transition-all duration-200">
                    {content.hero.cta.secondary}
                </a>
            </div>
        </div>

        <!-- Background Effects -->
        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute -top-32 -right-32 h-96 w-96 rounded-full bg-white/10 blur-3xl"></div>
            <div class="absolute bottom-0 left-0 h-64 w-64 rounded-full bg-white/5 blur-2xl"></div>
            <div class="absolute top-1/2 left-1/2 h-80 w-80 rounded-full bg-white/5 blur-3xl -translate-x-1/2 -translate-y-1/2"></div>
        </div>
    </section>

    <!-- Intro Section -->
    <section class="py-16 md:py-24 border-t border-white/10">
        <div class="max-w-4xl space-y-6 text-lg md:text-xl text-zinc-300 leading-relaxed">
            <p>{content.intro.paragraph1}</p>
            <p>{content.intro.paragraph2}</p>
            <p class="text-white font-medium">{content.intro.paragraph3}</p>
        </div>
    </section>

    <!-- Benefits Section -->
    <section class="py-16 md:py-24 border-t border-white/10">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{content.benefits.title}</h2>
        </div>
        <div class="grid md:grid-cols-3 gap-6 md:gap-8">
            {content.benefits.items.map((benefit) => (
                <div class="group rounded-2xl border border-white/10 bg-white/5 p-8 hover:bg-white/10 hover:border-white/20 transition-all duration-300 hover:scale-[1.02]">
                    <h3 class="text-xl font-semibold mb-3 text-white">{benefit.title}</h3>
                    <p class="text-zinc-300 leading-relaxed">{benefit.description}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- About/Services Section -->
    <section id="services" class="py-16 md:py-24 border-t border-white/10">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{content.about.title}</h2>
            <p class="text-xl md:text-2xl text-zinc-300 font-medium">{content.about.tagline}</p>
        </div>
        <div class="grid md:grid-cols-2 gap-6 md:gap-8">
            {content.about.services.map((service) => (
                <div class="group rounded-2xl border border-white/10 bg-gradient-to-br from-white/5 to-white/[0.02] p-8 hover:from-white/10 hover:to-white/5 hover:border-white/20 transition-all duration-300">
                    <h3 class="text-2xl font-semibold mb-4 text-white">{service.title}</h3>
                    <p class="text-zinc-300 leading-relaxed">{service.description}</p>
                </div>
            ))}
        </div>
    </section>

    <!-- Projects Section -->
    <section id="work" class="py-16 md:py-24 border-t border-white/10">
        <div class="mb-12">
            <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-4">{content.projects.title}</h2>
            <p class="text-lg md:text-xl text-zinc-300 mb-6">{content.projects.description}</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6 md:gap-8 mb-8">
            {content.projects.items.map((project) => (
                <div class="group aspect-[4/3] rounded-2xl border border-white/10 bg-gradient-to-br from-white/10 via-white/5 to-white/[0.02] hover:from-white/15 hover:via-white/10 hover:to-white/5 hover:border-white/20 transition-all duration-300 hover:scale-[1.02] cursor-pointer overflow-hidden relative">
                    <div class="absolute inset-0 flex items-center justify-center">
                        <span class="text-zinc-400 group-hover:text-white transition-colors font-medium">{project.name}</span>
                    </div>
                </div>
            ))}
        </div>
        <p class="text-zinc-400 text-center md:text-left italic">{content.projects.subtitle}</p>
    </section>

    <!-- CTA Section -->
    <section class="py-16 md:py-24 border-t border-white/10">
        <div class="rounded-3xl border border-white/10 bg-gradient-to-br from-white/10 via-white/5 to-white/[0.02] p-10 md:p-16 backdrop-blur-sm">
            <div class="max-w-3xl mx-auto text-center">
                <h2 class="text-3xl md:text-4xl lg:text-5xl font-bold mb-6">{content.cta.title}</h2>
                <p class="text-xl md:text-2xl text-zinc-300 mb-4 leading-relaxed">{content.cta.description}</p>
                <p class="text-lg md:text-xl text-zinc-400 mb-6 leading-relaxed">{content.cta.paragraph}</p>
                <p class="text-base md:text-lg text-zinc-500 mb-8">{content.cta.subtitle}</p>
                <a href="#contact" class="inline-flex items-center rounded-full bg-white text-black px-8 py-4 text-lg font-semibold hover:bg-zinc-100 transition-all duration-200 shadow-lg shadow-white/20 hover:shadow-xl hover:shadow-white/30 hover:scale-105">
                    {content.cta.button}
                </a>
            </div>
        </div>
    </section>

    <!-- Contact Section -->
    <section id="contact" class="py-16 md:py-24 border-t border-white/10">
        <div class="rounded-3xl border border-white/10 bg-white/5 backdrop-blur-sm p-10 md:p-12">
            <div class="flex flex-col md:flex-row md:items-center md:justify-between gap-8">
                <div class="flex-1">
                    <h3 class="text-2xl md:text-3xl font-bold mb-3">{content.contact.title}</h3>
                    <p class="text-lg text-zinc-300 leading-relaxed">{content.contact.description}</p>
                </div>
                <div class="flex flex-col sm:flex-row gap-4">
                    <a href={`mailto:${companyData.email}`} class="inline-flex items-center justify-center rounded-full bg-white text-black px-6 py-3.5 text-base font-semibold hover:bg-zinc-100 transition-all duration-200 shadow-lg shadow-white/20 hover:shadow-xl hover:shadow-white/30 hover:scale-105">
                        Email Us
                    </a>
                    <a href={`tel:${companyData.phone.primary.replace(/\s/g, '')}`} class="inline-flex items-center justify-center rounded-full border-2 border-white/30 bg-white/5 backdrop-blur-sm px-6 py-3.5 text-base font-semibold text-white hover:bg-white/10 hover:border-white/50 transition-all duration-200">
                        Call Us
                    </a>
                </div>
            </div>
        </div>
    </section>
</Layout>
