---
import Layout from "../layouts/Layout.astro";
import { content } from "../data/content";
import { companyData } from "../data/company";

const phonePrimaryClean = companyData.phone.primary.replace(/\s/g, '');
---

<Layout title={content.meta.title}>
    <section class="relative py-20 md:py-28">
        <div class="max-w-3xl">
            <h1 class="text-4xl md:text-6xl font-semibold tracking-tight leading-tight">
                {content.hero.title}
            </h1>
            <p class="mt-5 text-zinc-300 text-lg md:text-xl leading-relaxed">
                {content.hero.subtitle}
            </p>
            <p class="mt-4 text-zinc-400 text-base md:text-lg leading-relaxed">
                {content.hero.description}
            </p>
            <p class="mt-4 text-zinc-400 text-base md:text-lg leading-relaxed">
                {content.about.description}
            </p>
            <p class="mt-4 text-zinc-400 text-base md:text-lg leading-relaxed">
                {content.about.extended}
            </p>
            <p class="mt-4 text-zinc-300 text-base md:text-lg leading-relaxed">
                {content.about.tagline}
            </p>
            <div class="mt-8 flex flex-wrap gap-4">
                <a href="#contact" class="inline-flex items-center rounded-full bg-zinc-100 text-black px-5 py-3 text-sm font-medium hover:bg-white">
                    {content.hero.cta.primary}
                </a>
                <a href="#work" class="inline-flex items-center rounded-full border border-white/20 px-5 py-3 text-sm text-zinc-200 hover:bg-white/10">
                    {content.hero.cta.secondary}
                </a>
            </div>
        </div>

        <div class="pointer-events-none absolute inset-0 -z-10">
            <div class="absolute -top-24 right-0 h-72 w-72 rounded-full bg-white/10 blur-3xl"></div>
            <div class="absolute bottom-0 left-0 h-40 w-40 rounded-full bg-white/5 blur-2xl"></div>
        </div>
    </section>

    <section class="py-16 md:py-24 border-t border-white/10">
        <div class="max-w-3xl">
            <h2 class="text-2xl md:text-3xl font-semibold mb-4">{content.benefits.title}</h2>
            <ul class="space-y-3 text-zinc-300">
                {content.benefits.items.map((item) => (
                    <li class="flex items-start gap-3">
                        <span class="text-zinc-400 mt-1">●</span>
                        <span>{item}</span>
                    </li>
                ))}
            </ul>
        </div>
    </section>

    <section class="py-16 md:py-24 border-t border-white/10">
        <div class="max-w-3xl mb-8">
            <h2 class="text-2xl md:text-3xl font-semibold">{content.mission.title}</h2>
            <p class="mt-3 text-zinc-300 text-lg">{content.mission.tagline}</p>
        </div>
    </section>

    <section id="services" class="py-16 md:py-24 border-t border-white/10">
        <div class="grid md:grid-cols-3 gap-8">
            <div class="col-span-1 md:col-span-1">
                <h2 class="text-2xl md:text-3xl font-semibold">{content.services.title}</h2>
            </div>
            <div class="grid grid-cols-1 gap-6 md:col-span-2">
                {content.services.items.map((service) => (
                    <div class="rounded-2xl border border-white/10 bg-white/5 p-6">
                        <h3 class="font-medium">{service.title}</h3>
                        <p class="mt-2 text-sm text-zinc-300">{service.description}</p>
                    </div>
                ))}
            </div>
        </div>
    </section>

    <section id="work" class="py-16 md:py-24 border-t border-white/10">
        <div class="mb-8">
            <h2 class="text-2xl md:text-3xl font-semibold">{content.projects.title}</h2>
            <p class="mt-3 text-zinc-300">{content.projects.description}</p>
        </div>
        <div class="grid md:grid-cols-3 gap-6">
            {content.projects.items.map((project) => (
                <div class="aspect-[4/3] rounded-xl border border-white/10 bg-gradient-to-br from-white/10 to-white/5 flex items-center justify-center">
                    <span class="text-zinc-400 text-sm">{project.name}</span>
                </div>
            ))}
        </div>
        <p class="mt-6 text-zinc-400 text-sm">{content.projects.footer}</p>
    </section>

    <section class="py-16 md:py-24 border-t border-white/10">
        <div class="max-w-3xl">
            <h2 class="text-2xl md:text-3xl font-semibold mb-4">{content.cta.title}</h2>
            <p class="text-zinc-300 text-lg mb-4">{content.cta.description}</p>
            <p class="text-zinc-300 mb-4">{content.cta.extended}</p>
            <p class="text-zinc-300 mb-6">{content.cta.final}</p>
            <a href="#contact" class="inline-flex items-center rounded-full bg-zinc-100 text-black px-5 py-3 text-sm font-medium hover:bg-white">
                {content.cta.button}
            </a>
        </div>
    </section>

    <section id="contact" class="py-16 md:py-24 border-t border-white/10">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-8 md:p-12">
            <div class="mb-6">
                <h3 class="text-xl md:text-2xl font-semibold mb-2">{content.contact.title}</h3>
                <p class="text-zinc-300 mb-4">{content.contact.description}</p>
            </div>
            <div class="flex flex-col gap-4 text-sm text-zinc-300">
                <a href={`tel:${phonePrimaryClean}`} class="hover:text-white flex items-center gap-2">
                    <span>📞</span>
                    <span>{companyData.phone.primary} | {companyData.phone.secondary}</span>
                </a>
                <a href={`mailto:${companyData.email}`} class="hover:text-white flex items-center gap-2">
                    <span>📧</span>
                    <span>{companyData.email}</span>
                </a>
                <a href={companyData.social.instagram.url} target="_blank" rel="noopener noreferrer" class="hover:text-white flex items-center gap-2">
                    <span>📸</span>
                    <span>Instagram: {companyData.social.instagram.handle}</span>
                </a>
            </div>
            <div class="mt-6">
                <a href={`mailto:${companyData.email}`} class="inline-flex items-center rounded-full bg-zinc-100 text-black px-5 py-3 text-sm font-medium hover:bg-white">
                    Email {companyData.email}
                </a>
            </div>
        </div>
    </section>
</Layout>
